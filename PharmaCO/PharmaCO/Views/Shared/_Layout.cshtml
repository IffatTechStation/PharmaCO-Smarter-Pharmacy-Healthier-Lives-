@using System.Web.Optimization
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - PharmaCO</title>

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- jQuery UI CSS (CDN) -->
    <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: #f4f6f9;
            color: #212529;
        }
        .dock {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: #004085;
            color: #fff;
            display: flex;
            align-items: center;
            overflow-x: auto;
            padding: 10px;
            z-index: 1100;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        .dock a {
            flex: 0 0 auto;
            margin: 0 8px;
            color: #e9ecef;
            text-decoration: none;
            padding: 8px 14px;
            border-radius: 6px;
            transition: .2s;
        }
        .dock a.active {
            background: #ffc107;
            color: #212529;
            font-weight: 600;
        }
        .dock a:hover { background: rgba(255,255,255,0.2); }
        .dock .auth { margin-left: auto; color: #fff; }
        .content { padding: 80px 25px 25px; min-height: 100vh; }
        footer { margin-top: 40px; text-align: center; color: #6c757d; font-size: 0.9rem; }
        @@media (max-width:768px) {
            .dock { top: auto; bottom: 0; }
            .content { padding: 25px; }
        }
    </style>
</head>
<body>
    <nav class="dock" role="navigation" aria-label="Main navigation">
        @{
            var currentController = (ViewContext.RouteData.Values["controller"] ?? "").ToString();
            var currentAction = (ViewContext.RouteData.Values["action"] ?? "").ToString();
            Func<string, bool> isController = c => string.Equals(currentController, c, StringComparison.OrdinalIgnoreCase);
            Func<string, bool> isAction = a => string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase);
        }

        <a href="@Url.Action("Index","Home")" class="@(isController("Home") ? "active" : "")"><i class="fas fa-home"></i> Home</a>
        <a href="@Url.Action("Index","Customer")" class="@(isController("Customer") ? "active" : "")"><i class="fas fa-users"></i> Customers</a>
        <a href="@Url.Action("Index","Medicine")" class="@(isController("Medicine") ? "active" : "")"><i class="fas fa-pills"></i> Medicines</a>
        <a href="@Url.Action("Index","Order")" class="@(isController("Order") ? "active" : "")"><i class="fas fa-shopping-cart"></i> Orders</a>

        @if (User != null && User.IsInRole("Owner"))
        {
            <a href="@Url.Action("Index","Report")" class="@(isController("Report") ? "active" : "")"><i class="fas fa-chart-line"></i> Reports</a>
            <a href="@Url.Action("OwnerDashboard","Home")" class="@(isAction("OwnerDashboard") ? "active" : "")"><i class="fas fa-user-shield"></i> Owner Dashboard</a>
        }
        else if (User != null && User.IsInRole("SalesMan"))
        {
            <a href="@Url.Action("SalesManDashboard","Home")" class="@(isAction("SalesManDashboard") ? "active" : "")"><i class="fas fa-user-tie"></i> SalesMan Dashboard</a>
        }

        <a href="@Url.Action("About","Home")" class="@(isAction("About") ? "active" : "")"><i class="fas fa-info-circle"></i> About</a>
        <a href="@Url.Action("Contact","Home")" class="@(isAction("Contact") ? "active" : "")"><i class="fas fa-phone-alt"></i> Contact</a>

        <div class="auth">@Html.Partial("_LoginPartial")</div>
    </nav>

    <main class="content" role="main">
        @RenderBody()
        <footer class="py-3 border-top">
            <p class="mb-0">&copy; @DateTime.Now.Year - PharmaCO | Designed with care for smarter pharmacy management</p>
        </footer>
    </main>

    <!-- jQuery and Bootstrap bundles (if you use bundles) -->
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    <!-- Simple CDN fallback: if bundles not present, load CDN scripts -->
    <script>
        if (typeof jQuery === 'undefined') {
            var s = document.createElement('script');
            s.src = "https://code.jquery.com/jquery-3.6.0.min.js";
            s.crossOrigin = "anonymous";
            document.head.appendChild(s);
        }
    </script>

    <!-- Load jQuery UI (CDN). Keep it simple: load directly -->
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>

    <!-- Helpful console warning if jQuery UI missing -->
    <script>
        (function () {
            if (typeof jQuery === 'undefined') {
                console.warn('jQuery not loaded. Autocomplete will not work.');
            } else if (!jQuery.ui) {
                console.warn('jQuery UI not loaded. Autocomplete will not work.');
            }
        })();
    </script>

    @RenderSection("Scripts", required: false)

    <script>
        function toggleSidebar() {
            var sb = document.getElementById("sidebar");
            if (sb) sb.classList.toggle("active");
        }
    </script>
</body>
</html>
