@model PagedList.IPagedList<PharmaCO.Models.Medicine>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Medicines";
    Layout = "~/Views/Shared/_Layout.cshtml";

    IEnumerable<string> categories = ViewBag.Categories as IEnumerable<string>
                                     ?? (Model != null
                                         ? Model.Select(m => m.Category).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c)
                                         : Enumerable.Empty<string>());

    IEnumerable<string> companies = ViewBag.Companies as IEnumerable<string>
                                     ?? (Model != null
                                         ? Model.Select(m => m.CompanyName).Where(c => !string.IsNullOrEmpty(c)).Distinct().OrderBy(c => c)
                                         : Enumerable.Empty<string>());

    var isOwner = User.IsInRole("Owner");
    var isSalesMan = User.IsInRole("SalesMan");

    Func<decimal?, string> formatTaka = p => p.HasValue ? String.Format("৳{0:N2}", p.Value) : "-";
}

<style>
    :root{
        --card-radius:12px; --card-gap:1rem; --accent:#0d6efd; --muted:#6c757d;
        --card-shadow:0 2px 8px rgba(13,110,253,0.06); --card-shadow-hover:0 10px 30px rgba(13,110,253,0.12);
    }
    .filter-card { border-radius:10px; padding:.75rem; background:linear-gradient(180deg,#fff,#fbfdff); box-shadow:0 1px 6px rgba(0,0,0,0.04); }
    .med-grid { display:grid; gap:var(--card-gap); grid-template-columns:repeat(5,1fr); }
    @@media (max-width:1400px){ .med-grid{grid-template-columns:repeat(4,1fr);} }
    @@media (max-width:1200px){ .med-grid{grid-template-columns:repeat(3,1fr);} }
    @@media (max-width:992px){ .med-grid{grid-template-columns:repeat(2,1fr);} }
    @@media (max-width:576px){ .med-grid{grid-template-columns:repeat(1,1fr);} }

    .med-card { border-radius:var(--card-radius); overflow:hidden; background:#fff; box-shadow:var(--card-shadow); transition:transform .22s ease, box-shadow .22s ease; display:flex; flex-direction:column; min-height:260px; border:1px solid rgba(13,110,253,0.03); }
    .med-card:focus { outline: none; box-shadow: var(--card-shadow-hover); transform: translateY(-6px) scale(1.02); }
    .card-img-top { height:140px; object-fit:cover; width:100%; background:#f5f7fb; }
    .img-fallback{ height:140px; display:flex; align-items:center; justify-content:center; color:var(--muted); background:linear-gradient(180deg,#f8fafc,#eef4ff); font-weight:600; }
    .card-body{ padding:12px; display:flex; flex-direction:column; gap:8px; flex:1 1 auto; }
    .card-title { display:flex; justify-content:space-between; align-items:center; gap:8px; }
    .card-title .name { font-weight:700; font-size:1rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:70%; }
    .meta { font-size:0.9rem; color:var(--muted); display:flex; flex-direction:column; gap:4px; }
    .card-actions{ display:flex; gap:8px; justify-content:center; padding-top:6px; flex-wrap:wrap; }
    .hint { font-size:0.9rem; color:#6c757d; margin-left:8px; align-self:center; }
    .badge-low { background:#ffc107; color:#212529; padding:.25rem .5rem; border-radius:.375rem; font-size:.75rem; }
    .badge-exp { background:#dc3545; color:#fff; padding:.25rem .5rem; border-radius:.375rem; font-size:.75rem; }
    .med-table { width:100%; border-collapse:collapse; }
    .med-table thead th { text-align:left; padding:10px; background:linear-gradient(90deg, rgba(13,110,253,0.04), rgba(13,110,253,0.01)); font-weight:600; }
    .med-table tbody td { padding:10px; border-bottom:1px solid rgba(0,0,0,0.04); vertical-align:middle; }
    .custom-pager-wrap{ display:inline-flex; background:#f8f9ff; padding:8px 12px; border-radius:999px; align-items:center; gap:8px; }
    .view-toggle .btn.active { background-color: var(--accent); color: #fff; font-weight:600; }
    .empty-state { text-align:center; padding:40px 20px; color:var(--muted); }
</style>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3 gap-2">
        <div>
            <h2 class="mb-0">💊 Medicine Inventory</h2>
            <small class="text-muted">Browse, filter and manage medicines</small>
        </div>

        <div class="d-flex align-items-center gap-2">
            <div class="view-toggle me-2" role="tablist" aria-label="View toggle">
                <button id="btnCard" class="btn btn-outline-secondary btn-sm active" type="button" aria-pressed="true" aria-controls="cardView">🔲 Card</button>
                <button id="btnTable" class="btn btn-outline-secondary btn-sm" type="button" aria-pressed="false" aria-controls="tableView">📋 Table</button>
            </div>

            @if (isOwner)
            {
                @Html.ActionLink("➕ Add New", "Create", null, new { @class = "btn btn-success" })
            }
            else if (isSalesMan)
            {
                <span class="hint">Limited actions for SalesMan</span>
            }
        </div>
    </div>

    <div class="filter-card mb-3">
        @using (Html.BeginForm("Index", "Medicine", FormMethod.Get, new { @class = "row g-2 align-items-center filter-row", role = "search" }))
        {
            <div class="col-12 col-sm-5 col-md-4">
                <input type="text" name="search" id="quickSearch" value="@ViewBag.Search" class="form-control" placeholder="🔍 Search medicines, company..." aria-label="Search medicines" />
            </div>

            <div class="col-6 col-sm-3 col-md-2">
                <select name="categoryFilter" class="form-select" aria-label="Filter by category">
                    <option value="">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat" @(ViewBag.CategoryFilter != null && ViewBag.CategoryFilter.ToString() == cat ? "selected" : "")>@cat</option>
                    }
                </select>
            </div>

            <div class="col-6 col-sm-3 col-md-2">
                <select name="companyFilter" class="form-select" aria-label="Filter by company">
                    <option value="">All Companies</option>
                    @foreach (var comp in companies)
                    {
                        <option value="@comp" @(ViewBag.CompanyFilter != null && ViewBag.CompanyFilter.ToString() == comp ? "selected" : "")>@comp</option>
                    }
                </select>
            </div>

            <div class="col-6 col-sm-4 col-md-2">
                <select name="sortOrder" class="form-select" aria-label="Sort medicines">
                    <option value="">Sort By</option>
                    <option value="name" @(ViewBag.SortOrder == "name" ? "selected" : "")>Name ↑</option>
                    <option value="name_desc" @(ViewBag.SortOrder == "name_desc" ? "selected" : "")>Name ↓</option>
                    <option value="price" @(ViewBag.SortOrder == "price" ? "selected" : "")>Price ↑</option>
                    <option value="price_desc" @(ViewBag.SortOrder == "price_desc" ? "selected" : "")>Price ↓</option>
                </select>
            </div>

            <div class="col-6 col-sm-2 col-md-1">
                <button type="submit" class="btn btn-primary w-100">Go</button>
            </div>
        }
    </div>

    <!-- Card view -->
    <div id="cardView" aria-live="polite">
        <div class="med-grid mb-3" id="medCards">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="med-card" role="article" aria-label="@item.Name" tabindex="0">
                        @if (!string.IsNullOrEmpty(item.ImagePath))
                        {
                            <img src="@Url.Content(item.ImagePath)" class="card-img-top" alt="@item.Name" />
                        }
                        else
                        {
                            <div class="img-fallback">No Image</div>
                        }

                        <div class="card-body">
                            <div class="card-title">
                                <span class="name" title="@item.Name">@item.Name</span>
                                <span>
                                    @if (item.Stock <= 10)
                                    {<span class="badge-low">Low</span>}
                                    @if (item.ExpiryDate != null && item.ExpiryDate <= DateTime.Today)
                                    {<span class="badge-exp ms-1">Expired</span>}
                                </span>
                            </div>

                            <div class="meta compact-meta">
                                <div><strong>Company:</strong> @(!string.IsNullOrEmpty(item.CompanyName) ? item.CompanyName : "-")</div>
                                <div><strong>Category:</strong> @(!string.IsNullOrEmpty(item.Category) ? item.Category : "-")</div>
                                <div><strong>Price:</strong> @formatTaka(item.Price) &nbsp; | &nbsp; <strong>Stock:</strong> @item.Stock</div>
                                <div><strong>Expiry:</strong> @(item.ExpiryDate != null ? item.ExpiryDate.ToString("yyyy-MM-dd") : "-")</div>
                            </div>

                            <div class="card-actions mt-auto">
                                <a class="btn btn-sm btn-info text-white" title="Details" href="@Url.Action("Details", "Medicine", new { id = item.MedicineId })" aria-label="Details @item.Name">🔍 Details</a>

                                @if (isOwner)
                                {
                                    <a class="btn btn-sm btn-warning" title="Edit" href="@Url.Action("Edit", "Medicine", new { id = item.MedicineId })" aria-label="Edit @item.Name">✏️ Edit</a>
                                    @Html.ActionLink("🗑️ Delete", "Delete", new { id = item.MedicineId }, new { @class = "btn btn-sm btn-danger", title = "Delete", aria_label = "Delete " + item.Name, onclick = "return confirm('Are you sure you want to delete this medicine?');" })
                                }
                                else if (isSalesMan)
                                {
                                    <a class="btn btn-sm btn-success" href="@Url.Action("Create", "Order", new { medicineId = item.MedicineId })" title="Create order">🛒 Order</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <h5>No medicines found</h5>
                    <p class="mb-2">Try adjusting filters or add a new medicine.</p>
                    @if (isOwner)
                    {
                        @Html.ActionLink("➕ Add Medicine", "Create", null, new { @class = "btn btn-success" })
                    }
                </div>
            }
        </div>
    </div>

    <!-- Table view (hidden by default) -->
    <div id="tableView" style="display:none;">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive mb-3">
                <table class="med-table">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Company</th>
                            <th>Category</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Expiry</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@(!string.IsNullOrEmpty(item.CompanyName) ? item.CompanyName : "-")</td>
                                <td>@(!string.IsNullOrEmpty(item.Category) ? item.Category : "-")</td>
                                <td>@formatTaka(item.Price)</td>
                                <td class="@(item.Stock <= 10 ? "text-danger fw-bold" : "")">@item.Stock</td>
                                <td>@(item.ExpiryDate != null ? item.ExpiryDate.ToString("yyyy-MM-dd") : "-")</td>
                                <td>
                                    <div style="display:flex; gap:8px; justify-content:flex-end; flex-wrap:wrap;">
                                        <a class="btn btn-sm btn-info text-white" href="@Url.Action("Details", "Medicine", new { id = item.MedicineId })">🔍 Details</a>

                                        @if (isOwner)
                                        {
                                            <a class="btn btn-sm btn-warning" href="@Url.Action("Edit", "Medicine", new { id = item.MedicineId })">✏️ Edit</a>
                                            @Html.ActionLink("🗑️ Delete", "Delete", new { id = item.MedicineId }, new { @class = "btn btn-sm btn-danger", onclick = "return confirm('Are you sure you want to delete this medicine?');" })
                                        }
                                        else if (isSalesMan)
                                        {
                                            <a class="btn btn-sm btn-success" href="@Url.Action("Create", "Order", new { medicineId = item.MedicineId })">🛒 Order</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <!-- Footer: pager -->
    <div class="d-flex justify-content-between align-items-center mt-2">
        <div>
            <small class="text-muted">Showing @Model.FirstItemOnPage - @Model.LastItemOnPage of @Model.TotalItemCount</small>
        </div>
        <div>
            <div class="custom-pager-wrap" role="navigation" aria-label="Medicines pagination">
                @Html.PagedListPager(Model, page => Url.Action("Index", new
                {
                    page,
                    search = ViewBag.Search,
                    categoryFilter = ViewBag.CategoryFilter,
                    companyFilter = ViewBag.CompanyFilter,
                    sortOrder = ViewBag.SortOrder
                }), new PagedListRenderOptions
                {
                    UlElementClasses = new[] { "custom-pager" },
                    LiElementClasses = new[] { "page-item" },
                    DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                    DisplayLinkToLastPage = PagedListDisplayMode.Always,
                    DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                    DisplayLinkToNextPage = PagedListDisplayMode.Always,
                    LinkToPreviousPageFormat = "‹",
                    LinkToNextPageFormat = "›",
                    DisplayLinkToIndividualPages = true,
                    MaximumPageNumbersToDisplay = 7
                })
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        (function () {
            // Elements
            var btnCard = document.getElementById('btnCard');
            var btnTable = document.getElementById('btnTable');
            var cardView = document.getElementById('cardView');
            var tableView = document.getElementById('tableView');
            var input = document.getElementById('quickSearch');
            var grid = document.getElementById('medCards');

            // Remember last view in localStorage
            var VIEW_KEY = 'med_view_pref';
            function setView(isCard) {
                if (isCard) {
                    cardView.style.display = '';
                    tableView.style.display = 'none';
                    btnCard.classList.add('active');
                    btnTable.classList.remove('active');
                    btnCard.setAttribute('aria-pressed', 'true');
                    btnTable.setAttribute('aria-pressed', 'false');
                    localStorage.setItem(VIEW_KEY, 'card');
                } else {
                    cardView.style.display = 'none';
                    tableView.style.display = '';
                    btnCard.classList.remove('active');
                    btnTable.classList.add('active');
                    btnCard.setAttribute('aria-pressed', 'false');
                    btnTable.setAttribute('aria-pressed', 'true');
                    localStorage.setItem(VIEW_KEY, 'table');
                }
            }

            // Initialize view from preference
            try {
                var pref = localStorage.getItem(VIEW_KEY);
                setView(pref !== 'table');
            } catch (e) {
                setView(true);
            }

            btnCard.addEventListener('click', function () { setView(true); });
            btnTable.addEventListener('click', function () { setView(false); });

            // Debounced client-side search for card & table (non-destructive)
            function debounce(fn, delay) {
                var t;
                return function () {
                    var args = arguments;
                    clearTimeout(t);
                    t = setTimeout(function () { fn.apply(null, args); }, delay);
                };
            }

            function filterCards(q) {
                if (!grid) return;
                var cards = grid.querySelectorAll('.med-card');
                cards.forEach(function (card) {
                    var text = (card.innerText || '').toLowerCase();
                    card.style.display = q === '' || text.indexOf(q) !== -1 ? '' : 'none';
                });
            }

            function filterTable(q) {
                var rows = document.querySelectorAll('#tableView table tbody tr');
                rows.forEach(function (row) {
                    var text = (row.innerText || '').toLowerCase();
                    row.style.display = q === '' || text.indexOf(q) !== -1 ? '' : 'none';
                });
            }

            if (input) {
                var onInput = debounce(function () {
                    var q = input.value.trim().toLowerCase();
                    filterCards(q);
                    filterTable(q);
                }, 180);

                input.addEventListener('input', onInput);
                input.addEventListener('keyup', function (e) { if (e.key === 'Enter') this.form.submit(); });
            }

            // Keyboard focus styling for accessibility
            document.querySelectorAll('.med-card').forEach(function (card) {
                card.addEventListener('focus', function () {
                    card.style.boxShadow = 'var(--card-shadow-hover)';
                    card.style.transform = 'translateY(-6px) scale(1.02)';
                });
                card.addEventListener('blur', function () {
                    card.style.boxShadow = '';
                    card.style.transform = '';
                });
            });

            // Ensure table view rows are keyboard accessible
            document.querySelectorAll('#tableView tbody tr').forEach(function (tr) {
                tr.setAttribute('tabindex', '0');
            });
        })();
    </script>
}
