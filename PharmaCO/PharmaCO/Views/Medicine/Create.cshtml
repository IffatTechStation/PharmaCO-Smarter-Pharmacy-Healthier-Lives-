@model PharmaCO.Models.Medicine
@{
    ViewBag.Title = "Add Medicine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-3">➕ Add Medicine</h2>

@using (Html.BeginForm("Create", "Medicine", FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <div class="card shadow-lg border-0 mb-4">
        <div class="row g-0">
            <!-- Left side: Image Upload -->
            <div class="col-md-4 bg-light d-flex flex-column align-items-center justify-content-center p-3">
                <h5 class="fw-semibold mb-3">Upload Image</h5>
                <div class="border rounded d-flex align-items-center justify-content-center bg-white mb-3" style="height:220px; width:100%;">
                    <span class="text-muted">No Image Selected</span>
                </div>
                <input type="file" name="ImageFile" class="form-control" />
            </div>

            <!-- Right side: Form Fields -->
            <div class="col-md-8 p-4">
                <h5 class="fw-semibold mb-3">Medicine Information</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Name, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control", placeholder = "Enter medicine name" })
                        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(m => m.CompanyName, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.CompanyName, new { @class = "form-control", placeholder = "Enter company name" })
                        @Html.ValidationMessageFor(m => m.CompanyName, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6">
                        @Html.LabelFor(m => m.Category, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Category, new { @class = "form-control", placeholder = "Enter category" })
                        @Html.ValidationMessageFor(m => m.Category, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Price, new { @class = "form-label fw-semibold" })
                        <div class="input-group">
                            <span class="input-group-text">৳</span>
                            @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01" })
                        </div>
                        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        @Html.LabelFor(m => m.Stock, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.Stock, new { @class = "form-control", type = "number" })
                        @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4">
                        @Html.LabelFor(m => m.ExpiryDate, new { @class = "form-label fw-semibold" })
                        @Html.TextBoxFor(m => m.ExpiryDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                        @Html.ValidationMessageFor(m => m.ExpiryDate, "", new { @class = "text-danger" })
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="card-footer bg-light d-flex justify-content-start gap-2">
            <button type="submit" class="btn btn-success px-4">
                💾 Save Record
            </button>
            @Html.ActionLink("🏪 Back to Inventory", "Index", null, new { @class = "btn btn-outline-secondary px-4" })
        </div>
    </div>
}
