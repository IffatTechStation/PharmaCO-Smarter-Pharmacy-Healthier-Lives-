@model PagedList.IPagedList<PharmaCO.Models.Customer>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var searchValue = Request["search"] ?? "";
    var isOwner = User.IsInRole("Owner");
    var isSalesMan = User.IsInRole("SalesMan");
}

<style>
    /* compact styles (kept minimal so you can merge with your existing CSS) */
    .page-header { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:18px; }
    .controls { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .card-table { border-radius:12px; overflow:hidden; box-shadow:0 6px 18px rgba(20,20,50,0.06); border:1px solid rgba(99,102,241,0.06); background:#fff; }
    .table thead th { background: linear-gradient(90deg, rgba(99,102,241,0.06), rgba(99,102,241,0.02)); border-bottom:none; font-weight:600; }
    .action-btn { display:flex; gap:8px; justify-content:flex-end; white-space:nowrap; }
    .empty-state { padding:36px; text-align:center; color:#6c757d; }
    .hint { font-size:0.9rem; color:#6c757d; margin-left:8px; }
    .custom-pager-wrap { display:inline-flex; background:#f8f9ff; padding:8px 12px; border-radius:999px; align-items:center; gap:8px; }
    .custom-pager { list-style:none; padding:0; margin:0; display:inline-flex; align-items:center; }
    .custom-pager .page-item { margin:0 4px; }
    .custom-pager .page-link { width:40px; height:40px; display:inline-flex; align-items:center; justify-content:center; border-radius:50%; color:#6c63ff; font-weight:600; border:1px solid transparent; }
    .custom-pager .page-link:hover { background:#6c63ff; color:#fff; box-shadow:0 6px 18px rgba(108,99,255,0.12); }
    .custom-pager .active .page-link { background:#6c63ff; color:#fff; box-shadow:0 8px 22px rgba(108,99,255,0.16); }
    @@media (max-width:767px) { .page-header { flex-direction:column; align-items:flex-start; } .action-btn { justify-content:flex-start; } }
</style>

<div class="container mt-4">
    <div class="page-header">
        <h2>Customers</h2>

        <div class="controls">
            @* Both Owner and SalesMan can create in your current controller setup.
                If you want to restrict creation later, change controller attributes. *@
            @Html.ActionLink("➕ Add New Customer", "Create", null, new { @class = "btn btn-success" })

            @using (Html.BeginForm("Index", "Customer", FormMethod.Get, new { @class = "d-flex gap-2 align-items-center", role = "search", style = "min-width:320px;" }))
            {
                <input type="text" name="search" id="quickSearch" value="@searchValue" class="form-control" placeholder="🔍 Quick search (client-side) or press Enter for server search..." aria-label="Search customers" />
                <input type="hidden" name="sortOrder" value="@ViewBag.SortOrder" />
                <button type="submit" class="btn btn-primary">Filter</button>
            }

            @* Small role hint for SalesMan so they understand limitations *@
            @if (isSalesMan)
            {
                <span class="hint">You cannot edit or delete from this list</span>
            }
        </div>
    </div>

    <div class="card-table">
        <div class="table-responsive">
            <table class="table mb-0" id="customerTable" aria-describedby="customerListDescription">
                <caption id="customerListDescription" class="visually-hidden">List of customers with actions</caption>
                <thead>
                    <tr>
                        <th>
                            @Html.ActionLink("Name", "Index", new { sortOrder = ViewBag.SortOrder == "name" ? "name_desc" : "name", search = Request["search"] })
                        </th>
                        <th style="width:100px;">
                            @Html.ActionLink("Age", "Index", new { sortOrder = ViewBag.SortOrder == "age" ? "age_desc" : "age", search = Request["search"] })
                        </th>
                        <th>Contact</th>
                        <th>Address</th>
                        <th style="width:220px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="align-middle">@item.Name</td>
                                <td class="align-middle">@item.Age</td>
                                <td class="align-middle">@item.Contact</td>
                                <td class="align-middle">@item.Address</td>
                                <td class="align-middle">
                                    <div class="action-btn" role="group" aria-label="Customer actions for @item.Name">
                                        @* Details always visible *@
                                        @Html.ActionLink("ℹ️ Details", "Details", new { id = item.CustomerId }, new { @class = "btn btn-outline-info btn-sm", title = "View details", role = "button", aria_label = "Details " + item.Name })

                                        @* Owner sees Edit/Delete; SalesMan sees quick actions only *@
                                        @if (isOwner)
                                        {
                                            @Html.ActionLink("✏️ Edit", "Edit", new { id = item.CustomerId }, new { @class = "btn btn-outline-warning btn-sm", title = "Edit customer", role = "button", aria_label = "Edit " + item.Name })
                                            @Html.ActionLink("🗑️ Delete", "Delete", new { id = item.CustomerId }, new { @class = "btn btn-outline-danger btn-sm", title = "Delete customer", role = "button", aria_label = "Delete " + item.Name, onclick = "return confirm('Are you sure you want to delete this customer?');" })
                                        }
                                        else if (isSalesMan)
                                        {
                                            <a class="btn btn-outline-secondary btn-sm" href="tel:@item.Contact" title="Call">📞 Call</a>
                                            <a class="btn btn-outline-success btn-sm" href="@Url.Action("Create","Order", new { customerId = item.CustomerId })" title="Create order">🛒 Order</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <h5>No customers found</h5>
                                    <p class="mb-2">Try adjusting your search or add a new customer.</p>
                                    @Html.ActionLink("➕ Add First Customer", "Create", null, new { @class = "btn btn-success" })
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="list-footer mt-3 d-flex justify-content-between align-items-center">
        <div class="meta">
            @if (Model != null)
            {
                <span>Showing <strong>@Model.FirstItemOnPage</strong> - <strong>@Model.LastItemOnPage</strong> of <strong>@Model.TotalItemCount</strong></span>
            }
        </div>

        <div>
            @if (Model != null)
            {
                <div class="custom-pager-wrap" role="navigation" aria-label="Customer list pagination">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new
                    {
                        page,
                        search = Request["search"],
                        sortOrder = ViewBag.SortOrder
                    }), new PagedListRenderOptions
                    {
                        UlElementClasses = new[] { "custom-pager" },
                        LiElementClasses = new[] { "page-item" },
                        DisplayLinkToFirstPage = PagedListDisplayMode.Never,
                        DisplayLinkToLastPage = PagedListDisplayMode.Never,
                        DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                        DisplayLinkToNextPage = PagedListDisplayMode.Always,
                        LinkToPreviousPageFormat = "‹",
                        LinkToNextPageFormat = "›",
                        DisplayLinkToIndividualPages = true,
                        MaximumPageNumbersToDisplay = 7
                    })
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>
        (function () {
            var input = document.getElementById('quickSearch');
            var table = document.getElementById('customerTable');
            if (!input || !table) return;

            var timeout = null;
            input.addEventListener('keyup', function (e) {
                var q = this.value.trim().toLowerCase();

                // Enter => submit server-side filter
                if (e.key === 'Enter') {
                    this.form.submit();
                    return;
                }

                // Debounce to reduce work
                clearTimeout(timeout);
                timeout = setTimeout(function () {
                    var rows = table.querySelectorAll('tbody tr');
                    rows.forEach(function (row) {
                        // Skip empty-state row
                        if (row.querySelector('.empty-state')) return;
                        var text = row.innerText.toLowerCase();
                        row.style.display = q === '' || text.indexOf(q) !== -1 ? '' : 'none';
                    });
                }, 180);
            });

            // Accessibility: left/right arrow to navigate pagination
            document.addEventListener('keydown', function (e) {
                if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
                var pager = document.querySelector('.custom-pager');
                if (!pager) return;
                if (e.key === 'ArrowRight') {
                    var next = pager.querySelector('a[rel="next"]');
                    if (next) next.click();
                } else if (e.key === 'ArrowLeft') {
                    var prev = pager.querySelector('a[rel="prev"]');
                    if (prev) prev.click();
                }
            });
        })();
    </script>
}
