@model PharmaCO.Models.Customer
@{
    ViewBag.Title = "Delete Customer";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="mb-4 text-danger fw-bold">🗑️ Delete Customer</h2>

<div class="alert alert-warning shadow-sm">
    <strong>⚠️ Warning:</strong> Are you sure you want to delete this customer?
    This action cannot be undone.
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Name</div>
            <div class="col-sm-9">@Model.Name</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Age</div>
            <div class="col-sm-9">@Model.Age</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Contact</div>
            <div class="col-sm-9">@Model.Contact</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Address</div>
            <div class="col-sm-9">@Model.Address</div>
        </div>
    </div>
</div>

@using (Html.BeginForm("DeleteConfirmed", "Customer", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.CustomerId)

    <div class="mt-3">
        <button type="submit" class="btn btn-danger px-4">
            🗑️ Confirm Delete
        </button>
        @Html.ActionLink("⬅ Back to List", "Index", null, new { @class = "btn btn-outline-secondary ms-2 px-4" })
    </div>
}
