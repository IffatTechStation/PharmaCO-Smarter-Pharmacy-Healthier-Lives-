@model PharmaCO.Models.Customer
@{
    ViewBag.Title = "Customer Details";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var isOwner = User.IsInRole("Owner");
    var isSalesMan = User.IsInRole("SalesMan");
}

<h2 class="mb-4 text-primary fw-bold">👤 Customer Details</h2>

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Name</div>
            <div class="col-sm-9">@Model.Name</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Age</div>
            <div class="col-sm-9">@Model.Age</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Contact</div>
            <div class="col-sm-9">@Model.Contact</div>
        </div>

        <div class="row mb-3">
            <div class="col-sm-3 fw-bold text-secondary">Address</div>
            <div class="col-sm-9">@Model.Address</div>
        </div>

        @* Optional: show a small hint for SalesMan so they understand limited actions *@
        @if (isSalesMan && !isOwner)
        {
            <div class="row mb-3">
                <div class="col-12">
                    <div class="alert alert-info py-2 mb-0">
                        You have view-only access here. Contact the owner for edits or deletions.
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    @* Details/back always available *@
    @Html.ActionLink("⬅ Back to List", "Index", null, new { @class = "btn btn-outline-secondary px-4 me-2" })

    @* Owner-only actions *@
    @if (isOwner)
    {
        @Html.ActionLink("✏️ Edit", "Edit", new { id = Model.CustomerId }, new { @class = "btn btn-warning px-4 me-2" })
        @Html.ActionLink("🗑️ Delete", "Delete", new { id = Model.CustomerId }, new { @class = "btn btn-danger px-4", onclick = "return confirm('Are you sure you want to delete this customer?');" })
    }

    @* SalesMan quick actions (optional) *@
    @if (isSalesMan && !isOwner)
    {
        <a class="btn btn-success px-4 ms-2" href="@Url.Action("Create", "Order", new { customerId = Model.CustomerId })">🛒 Create Order</a>
        <a class="btn btn-outline-secondary px-3 ms-2" href="tel:@Model.Contact">📞 Call</a>
    }
</div>
