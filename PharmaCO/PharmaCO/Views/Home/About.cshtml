@{
    ViewBag.Title = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="fw-bold text-primary mb-3">@ViewBag.Title</h2>
    <p class="text-muted">@ViewBag.Message</p>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body">
            <p>
                PharmaCO is a modern pharmacy management system designed to simplify medicine inventory,
                customer management, and order tracking. Use this area to provide additional information
                about your company, mission, or services.
            </p>
        </div>
    </div>
</div>
