@{
    ViewBag.Title = "Contact";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="fw-bold text-primary mb-3">@ViewBag.Title</h2>
    <p class="text-muted">@ViewBag.Message</p>

    <div class="row">
        <div class="col-md-6">
            <h5 class="fw-bold">📍 Address</h5>
            <address>
                One Microsoft Way<br />
                Redmond, WA 98052-6399<br />
                <abbr title="Phone">📞</abbr> 425.555.0100
            </address>

            <h5 class="fw-bold mt-4">✉️ Contact</h5>
            <address>
                <strong>Support:</strong> <a href="mailto:Support@example.com">Support@example.com</a><br />
                <strong>Marketing:</strong> <a href="mailto:Marketing@example.com">Marketing@example.com</a>
            </address>
        </div>

        <!-- Contact Form -->
        <div class="col-md-6">
            <h5 class="fw-bold">📬 Send us a message</h5>
            @using (Html.BeginForm("SendMessage", "Home", FormMethod.Post, new { @class = "mt-3" }))
            {
                <div class="mb-3">
                    <label for="Name" class="form-label">Name</label>
                    <input type="text" name="Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label for="Email" class="form-label">Email</label>
                    <input type="email" name="Email" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label for="Message" class="form-label">Message</label>
                    <textarea name="Message" class="form-control" rows="4" required></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Send Message</button>
            }
        </div>
    </div>
</div>
